{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "api/index.js" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "^/discover$", "dest": "/public/browse.html" },
    { "src": "^/messages$", "dest": "/public/chat.html" },
    { "src": "^/([a-zA-Z0-9_-]+)$", "dest": "/public/$1.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
